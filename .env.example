# Microsoft Graph app registration (Entra ID)
TENANT_ID=
CLIENT_ID=
CLIENT_SECRET=

# Identity URN namespace embedded in client cert SAN URIs
URN_PREFIX=urn:example.com

# Policy: declarative rules (JSON, first-match-wins) evaluated against facts
# derived from the cert + Graph lookups - see policy.example.json for the
# schema and README.md for the fact reference. If this file doesn't exist,
# a built-in default ruleset is used (compliant device -> access, known but
# non-compliant device -> untrust, disabled user/device or unresolved
# identity -> reject).
POLICY_RULES_FILE=/config/policy.json

# Escape hatch: skip Graph/policy entirely and allow anything FreeRADIUS's
# own cert verification already accepted.
TRUST_CHAIN_FALLBACK=false

# Optional: on-prem Active Directory device lookup over LDAPS, populating
# ad_device_found / ad_device_enabled facts for use in POLICY_RULES_FILE.
# Requires the device cert to carry a
# `<URN_PREFIX>:onprem-sid:{{OnPremisesSecurityIdentifier}}` SAN URI (Intune
# SCEP profile strong certificate mapping). The default ruleset does not
# reference these facts, so enabling this alone changes nothing until your
# policy.json adds rules for it.
AD_LDAP_ENABLED=false
AD_LDAP_SERVER=
AD_LDAP_PORT=636
AD_LDAP_USE_SSL=true
# Set to false to skip LDAPS certificate validation (self-signed/internal CA
# not in the container's trust store). Prefer fixing the trust store instead
# where possible.
AD_LDAP_VERIFY_CERT=true
AD_LDAP_BIND_USERNAME=
AD_LDAP_BIND_PASSWORD=
# Search base, e.g. dc=example,dc=com - required if AD_LDAP_ENABLED=true
AD_LDAP_BASE_DN=
AD_LDAP_TIMEOUT_SECONDS=10

# Graph behavior
GRAPH_TIMEOUT_SECONDS=20
GRAPH_MAX_RETRIES=1

# Cache backend: "sqlite" (single-file, default) or "postgres_redis"
CACHE_BACKEND=sqlite
LOCAL_CACHE_FIRST=true
LOCAL_CACHE_MAX_AGE_SECONDS=900

# Used when CACHE_BACKEND=postgres_redis
POSTGRES_DB=radius_cache
POSTGRES_USER=radius_app
POSTGRES_PASSWORD=
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_CACHE_TTL_SECONDS=300

# Device blocking (POST /block-device, /unblock-device, GET /blocked-devices)
# - requires CACHE_BACKEND=postgres_redis. A blocked MAC/Entra device ID/AD SID
# is rejected unconditionally, ahead of TRUST_CHAIN_FALLBACK and the policy
# engine, checked live (no caching) so a block takes effect immediately.
# Required to use those endpoints at all - with no key set, they refuse every
# request (fail closed) rather than accept unauthenticated writes.
ADMIN_API_KEY=

# Background cache refresh
LIVE_LOOKUP_CACHE_SECONDS=300
DEVICE_CACHE_REFRESH_SECONDS=900
USER_CACHE_REFRESH_ENABLED=true
USER_CACHE_REFRESH_SECONDS=1800
USER_CACHE_SOURCE=all

# Stale fallback (serve last-known cache if Graph is unreachable)
ALLOW_STALE_CACHE_ON_GRAPH_ERROR=true
MAX_STALE_CACHE_HOURS=24

# Used only when CACHE_BACKEND=sqlite
CACHE_DB_PATH=/data/intune-radius-cache.sqlite3

# Logs
INTUNE_AUTH_LOG=/logs/intune-auth.log
